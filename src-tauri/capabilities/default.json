{
  "identifier": "default",
  "description": "Default capabilities for AIDesk",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "shell:allow-open",
    "shell:allow-execute",
    "dialog:default",
    "dialog:allow-open",
    "notification:default",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "store:default",
    "updater:default",
    "process:allow-restart"
  ]
}
